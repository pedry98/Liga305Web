# Caddy does automatic HTTPS via Let's Encrypt for each domain listed below.
# Environment vars come from docker-compose (${SITE_DOMAIN}, ${API_DOMAIN}).

{$SITE_DOMAIN} {
    encode zstd gzip
    reverse_proxy web:80
}

{$API_DOMAIN} {
    encode zstd gzip
    # API handles its own routing — Steam OpenID callback (/signin-steam),
    # /auth/*, /avatars/* (uploaded files), and all controllers.
    reverse_proxy api:8080
}
