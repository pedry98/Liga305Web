# Copy to deploy/.env on the server and fill in.
# deploy/.env must be gitignored (it is — see repo .gitignore).

# --- Domain routing ---
# SITE_DOMAIN: where the Angular SPA lives (e.g. liga305.example.com)
# API_DOMAIN:  where the ASP.NET API lives  (e.g. liga305-api.example.com)
# Both must point at this VPS's IP. Caddy auto-fetches Let's Encrypt certs for each.
SITE_DOMAIN=liga305.example.com
API_DOMAIN=liga305-api.example.com

# --- Postgres ---
# Use your Neon connection string in Npgsql keyed format.
POSTGRES_CONN=Host=ep-xxx.region.aws.neon.tech;Database=neondb;Username=USER;Password=PASS;SslMode=Require;Trust Server Certificate=true

# --- Steam Web API key (for profile name/avatar enrichment) ---
# Register at https://steamcommunity.com/dev/apikey (any domain works).
STEAM_WEB_API_KEY=

# --- Internal bot-worker auth ---
# Any long random string. Must match between api and bot-worker.
WORKER_SHARED_SECRET=

# --- Bot Steam account (hosts the Dota 2 lobbies) ---
# See src/bot-worker/README.md for how to extract the shared_secret via SDA.
BOT_STEAM_USERNAME=
BOT_STEAM_PASSWORD=
BOT_STEAM_SHARED_SECRET=

# --- Dota lobby defaults ---
# Region: 0=Unspec, 1=USWest, 2=USEast, 3=Europe, 5=SEAsia, 6=SAmerica ...
# Mode:   1=All Pick, 2=Captain's Mode, 22=Ranked All Pick
DOTA_SERVER_REGION=2
DOTA_GAME_MODE=2

# Seconds to wait for 10 players in a lobby before auto-abandon.
ABANDON_TIMEOUT_SEC=240
