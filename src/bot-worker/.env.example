# Copy to .env and fill in. .env is gitignored.

PORT=4100
WORKER_SHARED_SECRET=dev-only-not-secure
API_BASE_URL=http://localhost:5080

# Real Dota 2 bot mode (without these, worker runs in simulation mode).
# Same Steam bot account / shared_secret you used for the Node worker.
BOT_STEAM_USERNAME=
BOT_STEAM_PASSWORD=
BOT_STEAM_SHARED_SECRET=

# Dota lobby defaults
#   Server region: 0=Unspecified, 1=USWest, 2=USEast, 3=Europe, 5=SE Asia, ...
#   Game mode: 1=All Pick, 2=Captains Mode, 22=Ranked All Pick (etc.)
DOTA_SERVER_REGION=2
DOTA_GAME_MODE=1

# How long (seconds) to wait for all 10 players before destroying the lobby.
ABANDON_TIMEOUT_SEC=240
