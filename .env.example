# Copy to .env and fill in. .env is gitignored.

# ---- Postgres (used by docker-compose AND the API connection string) ----
POSTGRES_DB=liga305
POSTGRES_USER=liga305
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ---- API (Phase 1+) ----
# The API reads ConnectionStrings__Postgres at runtime; matches the values above.
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=liga305;Username=liga305;Password=changeme

# Steam Web API key (server-side only, used to enrich profile after OpenID login).
# Get one at https://steamcommunity.com/dev/apikey
STEAM_WEB_API_KEY=

# JWT signing key for our own session cookies. Generate a long random string.
JWT_SIGNING_KEY=

# Shared secret between API and bot-worker (Phase 4+). Same value on both sides.
WORKER_SHARED_SECRET=

# ---- Bot worker (Phase 4+) ----
BOT_STEAM_USERNAME=
BOT_STEAM_PASSWORD=
BOT_STEAM_SHARED_SECRET=
API_BASE_URL=http://localhost:5080
